# Environment Variables

# Supabase Configuration
# Get these from your Supabase project: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Service Role Key (Server-side only - NEVER expose to client)
# This key bypasses RLS and should only be used in server actions and API routes
# Get it from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Model for voice/realtime features
OPENAI_REALTIME_MODEL=gpt-realtime-mini

# Firebase Configuration (for push notifications)
# Generate VAPID key in: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key-here

# Daily.co Configuration (for voice/video ChitChat)
# Get your API key from: https://dashboard.daily.co/developers
DAILY_API_KEY=your-daily-api-key-here

# Email Notifications (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key-here
# The "from" address for notification emails (must be a verified domain in Resend)
EMAIL_FROM=TaskFlow <notifications@yourdomain.com>
# Public app URL used to generate task links in emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

