{
  "name": "taskflow",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "overrides": {
      "zod": "4.0.8",
      "@modelcontextprotocol/sdk": "1.29.0"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@taskflow/web",
    "dev:mobile": "turbo dev --filter=@taskflow/mobile",
    "dev:desktop": "turbo tauri:dev --filter=@taskflow/desktop",
    "build": "turbo build",
    "build:web": "turbo build --filter=@taskflow/web",
    "build:mobile": "turbo build --filter=@taskflow/mobile",
    "build:desktop": "turbo tauri:build --filter=@taskflow/desktop",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "type-check": "turbo type-check",
    "check": "turbo lint type-check",
    "clean": "turbo clean && rm -rf node_modules .turbo",
    "clean:all": "turbo clean && rm -rf node_modules .turbo apps/*/node_modules packages/*/node_modules",
    "db:types": "npx supabase@latest gen types typescript --project-id vtnpgsmsxnkbhgvuisds > packages/core/src/types/database.ts",
    "db:push": "npx supabase@latest db push",
    "db:pull": "npx supabase@latest db pull",
    "db:reset": "npx supabase@latest db reset",
    "db:diff": "npx supabase@latest db diff",
    "db:migration": "npx supabase@latest migration new",
    "db:status": "npx supabase@latest migration list",
    "release:desktop": "node scripts/release-desktop.mjs"
  },
  "devDependencies": {
    "supabase": "^2.81.0",
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}