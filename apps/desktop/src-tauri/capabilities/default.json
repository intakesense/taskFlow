{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "notification:default",
    "autostart:default",
    "stronghold:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-create-dir",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-metadata",
    "fs:allow-watch",
    "fs:allow-unwatch"
  ]
}
