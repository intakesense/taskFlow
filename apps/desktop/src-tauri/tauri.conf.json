{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TaskFlow",
  "version": "0.1.5",
  "identifier": "com.taskflow.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TaskFlow",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://vtnpgsmsxnkbhgvuisds.supabase.co wss://vtnpgsmsxnkbhgvuisds.supabase.co https://tms.intakesense.com https://*.daily.co wss://*.daily.co; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "TaskFlow",
    "shortDescription": "Task management for teams",
    "longDescription": "TaskFlow is a hierarchical task management system with real-time collaboration, team chat, and notification features.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "taskflow"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGRkJCMzdGMEJDMjE3OTkKUldTWkY4SUxmN1A3anhtbDN2RVBXRklRTW9rNFUxVStNV1JOZlRaZ0hNdVVMajNpSjdwYURodTUK",
      "endpoints": [
        "https://github.com/XCRESS/taskFlow/releases/latest/download/latest.json"
      ]
    }
  }
}
